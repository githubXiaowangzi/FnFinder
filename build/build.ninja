#############################################
# Utility command for edit_cache

build external/capstone/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = C:\Windows\system32\cmd.exe /C "cd /D F:\ELF\FnFinder\build\external\capstone && E:\cpeditor\mingw64\bin\cmake.exe -E echo "No interactive CMake dialog available.""
  DESC = No interactive CMake dialog available...
  restat = 1

build external/capstone/edit_cache: phony external/capstone/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build external/capstone/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = C:\Windows\system32\cmd.exe /C "cd /D F:\ELF\FnFinder\build\external\capstone && E:\cpeditor\mingw64\bin\cmake.exe --regenerate-during-build -SF:\ELF\FnFinder -BF:\ELF\FnFinder\build"
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build external/capstone/rebuild_cache: phony external/capstone/CMakeFiles/rebuild_cache.util

# =============================================================================
# Target aliases.

build FnFinder: phony FnFinder.exe

